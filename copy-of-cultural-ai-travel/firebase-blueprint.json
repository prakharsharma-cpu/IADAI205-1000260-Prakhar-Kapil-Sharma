{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "description": "URL to the user's profile picture." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email"]
    },
    "Itinerary": {
      "title": "Travel Itinerary",
      "description": "A generated travel plan for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who owns this itinerary." },
        "destination": { "type": "string", "description": "The destination of the trip." },
        "duration": { "type": "integer", "description": "Length of the trip in days." },
        "preferences": { "type": "object", "description": "The preferences used to generate the itinerary." },
        "plan": { "type": "array", "description": "The day-by-day plan." },
        "imageUrl": { "type": "string", "description": "Generated image for the destination." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the itinerary was generated." }
      },
      "required": ["userId", "destination", "plan"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A single message in a chat conversation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "text": { "type": "string", "description": "The message text." },
        "sender": { "type": "string", "enum": ["user", "bot"], "description": "Who sent the message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." }
      },
      "required": ["userId", "text", "sender"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/itineraries/{itineraryId}": {
      "schema": "Itinerary",
      "description": "Collection of generated itineraries."
    },
    "/chats/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Chat history for each user."
    }
  }
}
